# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=ProClaim
ENVIRONMENT=development
DEBUG=true

# ── Security (generate with: openssl rand -hex 32) ───────────────────────────
SECRET_KEY=REPLACE_WITH_RANDOM_SECRET_KEY_32_CHARS_MIN

# ── Database ──────────────────────────────────────────────────────────────────
# For docker-compose, use the service name:
DATABASE_URL=postgresql+asyncpg://proclaim:proclaim_secret@localhost:5433/proclaim

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# ── Gemini (Primary Extractor) ────────────────────────────────────────────────
# Get a free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── First Admin User (seeded on first run) ────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@proclaim.ng
FIRST_ADMIN_PASSWORD=changeme123!

# ── CORS Origins ─────────────────────────────────────────────────────────────
# JSON array of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3001","http://localhost:5173"]

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/proclaim/uploads
MAX_UPLOAD_SIZE_MB=50

# ── HMO Submission (optional) ─────────────────────────────────────────────────
# If set, the "Submit to HMO" button will POST the claim JSON to this URL.
HMO_SUBMISSION_URL=

# ── Local Docker Compose ─────────────────────────────────────────────────────
# Host port for the frontend container. Change this if 3001 is already in use.
PROCLAIM_FRONTEND_PORT=3001
