# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=ProClaim
ENVIRONMENT=development
DEBUG=true

# ── Security (generate with: openssl rand -hex 32) ───────────────────────────
SECRET_KEY=a34650c60024cea083212ef9528feb2c4756d0e369eba14bb327faf111f7dcc9

# ── Database ──────────────────────────────────────────────────────────────────
# For docker-compose, use the service name:
DATABASE_URL=postgresql+asyncpg://proclaim:proclaim_secret@localhost:5433/proclaim

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# ── Gemini (Primary Extractor) ────────────────────────────────────────────────
GEMINI_API_KEY=REDACTED

# ── Azure Document Intelligence (Optional Fallback) ───────────────────────────

# ── First Admin User (seeded on first run) ────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@proclaim.ng
FIRST_ADMIN_PASSWORD=changeme123!


ALLOWED_ORIGINS=["http://localhost:3001","http://localhost:3002","http://localhost:5173"]
PROCLAIM_FRONTEND_PORT=3002

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/proclaim/uploads
MAX_UPLOAD_SIZE_MB=50
